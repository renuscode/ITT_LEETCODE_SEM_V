from typing import List

class Solution:
    def maxEnvelopes(self, envelopes: List[List[int]]) -> int:
        # Step 1: Sort widthuld just sort the envelopes from smallest to largest and stack them.s ascending, heights descending
        envelopes.sort(key=lambda x: (x[0], -x[1]))
        
        subseq = []
        for _, h in envelopes:
            # Step 2: Manual Binary Search (replaces bisect_left)
            left, right = 0, len(subseq)
            while left < right:
                mid = (left + right) // 2
                if subseq[mid] < h:
                    left = mid + 1
                else:
                    right = mid
            
            # Step 3: Insert or overwrite
            if left == len(subseq):
                subseq.append(h)
            else:
                subseq[left] = h
                
        return len(subseq)
